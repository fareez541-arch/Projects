#!/bin/bash

# ==============================================================================
#  RCCL P2P CONFIGURATION - MANDATORY FOR DUAL GFX1100
# ==============================================================================

# CRITICAL: Python 3.11 is RECOMMENDED for vLLM 0.6.3
# Python 3.12 causes schema errors with vLLM 0.6.3 due to list[int] type annotations
# If using Python 3.12, start_vllm.sh will attempt to auto-patch vLLM
# For best stability: conda install python=3.11

# CRITICAL: DO NOT INSTALL XFORMERS!
# xformers will pull CUDA torch and break ROCm compatibility
# vLLM works fine on ROCm without xformers (it's optional on AMD)

export HSA_FORCE_FINE_GRAIN_PCIE=1          # REQUIRED for P2P on RDNA3
export HSA_ENABLE_SDMA=1                    # Enable SDMA for P2P transfers (not 0!)
export RCCL_ENABLE_DIRECT_GPU_PEER=1        # Force direct GPU peer access
export RCCL_SOCKET_IFNAME=lo                # Fallback to loopback if P2P fails
export NCCL_DEBUG=INFO                      # Debug logging (remove after verification)
export RCCL_DEBUG=INFO                      # RCCL specific debug
export PYTORCH_HIP_ALLOC_CONF=expandable_segments:True,max_split_size_mb:512

# --- AGENT SPECIFIC PATHS ---
export CONDA_ENV_NAME="ccrn_agent"
export VLLM_MODEL="/home/fareez541/vllm_workspace/models/DeepSeek-R1-Distill-32B-AWQ"
export VLLM_GPU_MEMORY_UTILIZATION=0.90
export PYTHONNOUSERSITE=1

# PyTorch Installation Reference (ROCm 6.2):
# pip install torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 --index-url https://download.pytorch.org/whl/rocm6.2 --force-reinstall

# vLLM Installation Reference (ROCm 6.2, NO XFORMERS!):
# pip install vllm==0.6.3 --extra-index-url https://download.pytorch.org/whl/rocm6.2 --no-deps
# Then install deps manually: pip install numpy transformers fastapi uvicorn pydantic psutil sentencepiece requests tqdm py-cpuinfo tokenizers protobuf aiohttp openai lm-format-enforcer outlines filelock partial-json-parser pyzmq msgspec gguf importlib-metadata pyyaml einops ray tiktoken prometheus-client prometheus-fastapi-instrumentator
