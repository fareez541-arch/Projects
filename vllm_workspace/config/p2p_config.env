#!/bin/bash
# ==============================================================================
# RCCL P2P CONFIGURATION - MANDATORY FOR DUAL GFX1100
# ==============================================================================
# CRITICAL: Python 3.11 is REQUIRED for vLLM 0.6.3
# Python 3.12 causes schema errors with vLLM 0.6.3 due to list[int] type annotations
# DO NOT USE Python 3.12 - downgrade with: conda install python=3.11
# For best stability: conda install python=3.11

# CRITICAL: DO NOT INSTALL XFORMERS!
# xformers will pull CUDA torch and break ROCm compatibility
# vLLM works fine on ROCm without xformers (it's optional on AMD)

# CRITICAL: vLLM MUST BE BUILT FROM SOURCE FOR ROCm!
# PyPI wheels (pip install vllm) are CUDA-only and will fail with libc10_cuda.so errors
# Use start_vllm.sh which auto-builds from source, or manually:
#   export VLLM_TARGET_DEVICE=rocm
#   export PYTORCH_ROCM_ARCH=gfx1100
#   git clone --branch v0.6.3 --depth 1 https://github.com/vllm-project/vllm.git
#   cd vllm && python setup.py install

export HSA_FORCE_FINE_GRAIN_PCIE=1 # REQUIRED for P2P on RDNA3
export HSA_ENABLE_SDMA=1 # Enable SDMA for P2P transfers (not 0!)
export RCCL_ENABLE_DIRECT_GPU_PEER=1 # Force direct GPU peer access
export RCCL_SOCKET_IFNAME=lo # Fallback to loopback if P2P fails
export NCCL_DEBUG=INFO # Debug logging (remove after verification)
export RCCL_DEBUG=INFO # RCCL specific debug
export PYTORCH_HIP_ALLOC_CONF=expandable_segments:True,max_split_size_mb:512

# --- AGENT SPECIFIC PATHS ---
export CONDA_ENV_NAME="ccrn_agent"
export VLLM_MODEL="/home/fareez541/vllm_workspace/models/DeepSeek-R1-Distill-32B-AWQ"
export VLLM_GPU_MEMORY_UTILIZATION=0.90
export PYTHONNOUSERSITE=1

# PyTorch Installation Reference (ROCm 6.2):
# pip install torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 --index-url https://download.pytorch.org/whl/rocm6.2 --force-reinstall

# vLLM Installation Reference (ROCm 6.2, BUILD FROM SOURCE!):
# pip install cmake ninja packaging wheel setuptools-scm
# export VLLM_TARGET_DEVICE=rocm
# export PYTORCH_ROCM_ARCH=gfx1100
# export ROCM_HOME=/opt/rocm-6.2
# git clone --branch v0.6.3 --depth 1 https://github.com/vllm-project/vllm.git /tmp/vllm
# cd /tmp/vllm && python setup.py install
#
# Dependencies to install manually (if needed):
# pip install numpy transformers fastapi uvicorn pydantic psutil sentencepiece requests tqdm py-cpuinfo tokenizers protobuf aiohttp openai lm-format-enforcer outlines filelock partial-json-parser pyzmq msgspec gguf importlib-metadata pyyaml einops ray tiktoken prometheus-client prometheus-fastapi-instrumentator
